{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "alizharb/filament-activity-log": "^1.3",
        "andreia/filament-ui-switcher": "^1.0",
        "barryvdh/laravel-dompdf": "^3.1",
        "bezhansalleh/filament-language-switch": "^4.1",
        "bezhansalleh/filament-shield": "^4.1",
        "blade-ui-kit/blade-heroicons": "^2.6",
        "codeat3/blade-google-material-design-icons": "^1.19",
        "codeat3/blade-jam-icons": "^1.6",
        "codeat3/blade-system-uicons": "^1.7",
        "filament/filament": "^5.3",
        "filament/notifications": "^5.3",
        "filament/widgets": "^5.3",
        "joaopaulolndev/filament-edit-profile": "^3.0",
        "laravel/framework": "^12.0",
        "laravel/pulse": "^1.6",
        "laravel/scout": "^10.24",
        "laravel/tinker": "^2.9",
        "leandrocfe/filament-apex-charts": "^5.0",
        "pxlrbt/filament-excel": "^3.6",
        "saade/filament-fullcalendar": "^4.0@beta",
        "spatie/laravel-activitylog": "^4.12",
        "spatie/laravel-backup": "^9.4"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.2",
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "audit": {
            "ignore": [
                "PKSA-64jn-3d9t-gncx",
                "PKSA-8b16-mcgz-h4cz",
                "PKSA-s99r-9yxm-hjvt",
                "PKSA-7jd6-nb49-bz4v",
                "PKSA-nm34-xhtz-ww9p",
                "PKSA-4ckb-wpj6-c29d",
                "PKSA-ybqb-vyrq-8pdt",
                "PKSA-285y-y5bt-kvd9",
                "PKSA-jw5c-q9nd-tzj9",
                "PKSA-bcnb-9tc9-bjb8",
                "PKSA-gst3-cdk3-bpqt",
                "PKSA-dbrb-pvhs-h3st",
                "PKSA-mkg2-1wyw-57y7",
                "PKSA-p1pj-q951-6f1x",
                "PKSA-7f9v-sb8k-krfb",
                "PKSA-xk3k-rd1m-pxmg",
                "PKSA-dvbq-8ft2-ngrw",
                "PKSA-xp7t-fbrb-qjv4",
                "PKSA-m4hk-rk8p-4t5p"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
